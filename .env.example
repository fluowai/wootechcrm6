# =============================================================================
# WOOTECH CRM — AI-BOS ENVIRONMENT VARIABLES
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"

# ── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# ── LLM Providers (12 Free Tier) ────────────────────────────────────────────
# Todos são gratuitos. Obtenha suas chaves em:
# 1. Gemini: https://aistudio.google.com
# 2. Groq: https://console.groq.com
# 3. OpenRouter: https://openrouter.ai
# 4. Cerebras: https://cloud.cerebras.ai
# 5. NVIDIA NIM: https://build.nvidia.com
# 6. Mistral: https://console.mistral.ai
# 7. DeepSeek: https://platform.deepseek.com
# 8. HuggingFace: https://huggingface.co/settings/tokens
# 9. Cohere: https://dashboard.cohere.com
# 10. Cloudflare Workers AI: https://dash.cloudflare.com
# 11. Puter: https://docs.puter.com
# 12. Hermes (self-hosted): http://hermes:8642

GEMINI_API_KEY="your-gemini-key"
GROQ_API_KEY="your-groq-key"
OPENROUTER_API_KEY="your-openrouter-key"
CEREBRAS_API_KEY="your-cerebras-key"
NVIDIA_NIM_API_KEY="your-nvidia-nim-key"
MISTRAL_API_KEY="your-mistral-key"
DEEPSEEK_API_KEY="your-deepseek-key"
HUGGINGFACE_API_KEY="your-huggingface-key"
COHERE_API_KEY="your-cohere-key"
CLOUDFLARE_API_KEY="your-cloudflare-key"
PUTER_API_KEY="your-puter-key"

# ── AI-BOS: Hermes Agent (Self-Hosted LLM Gateway) ────────────────────────────
HERMES_URL="http://hermes:8642"
HERMES_DASHBOARD_PORT=9119
HERMES_DASHBOARD_PASS="admin"

# ── AI-BOS: Jarvis (Self-Hosted AI Assistant) ─────────────────────────────────
JARVIS_URL="http://jarvis:8443"
JARVIS_USERNAME="admin"
JARVIS_PASSWORD="admin"
JARVIS_SECRET="wootech-jarvis-secret-change-in-prod"

# ── Paperclip Runtime ────────────────────────────────────────────────────────
PAPERCLIP_PORT=4100
PAPERCLIP_SECRET_KEY="wootech-paperclip-secret-change-in-prod"

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://cache-redis:6379"

# ── Internal Services ────────────────────────────────────────────────────────
BROWSERLESS_URL="ws://browserless:3000"
BROWSERLESS_TOKEN="wootech-browserless-token"
FIRECRAWL_API_KEY="your-firecrawl-cloud-key"
UNSTRUCTURED_URL="http://unstructured:8000"
CNPJ_SERVICE_URL="http://cnpj-service:4000"
COLLY_SERVICE_URL="http://colly-service:5000"

# ── WhatsApp Bridge (Go Multi-Instance) ──────────────────────────────────────
WHATSAPP_BRIDGE_URL="http://whatsapp-bridge:8091"
WHATSAPP_BRIDGE_SECRET="wootech-wa-secret-change-in-prod"
