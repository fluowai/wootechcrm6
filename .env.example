# =============================================================================
# WOOTECH CRM — AI-BOS ENVIRONMENT VARIABLES
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"

# ── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# ── LLM Providers (Free Tier) ───────────────────────────────────────────────
# Todos são gratuitos. Obtenha suas chaves em:
# Gemini: https://aistudio.google.com
# Groq: https://console.groq.com
# OpenRouter: https://openrouter.ai
# Cerebras: https://cloud.cerebras.ai
# NVIDIA NIM: https://build.nvidia.com
# Mistral: https://console.mistral.ai
# DeepSeek: https://platform.deepseek.com
# Cohere: https://dashboard.cohere.com

GEMINI_API_KEY="your-gemini-key"
GROQ_API_KEY="your-groq-key"
OPENROUTER_API_KEY="your-openrouter-key"
CEREBRAS_API_KEY="your-cerebras-key"
NVIDIA_NIM_API_KEY="your-nvidia-nim-key"
MISTRAL_API_KEY="your-mistral-key"
DEEPSEEK_API_KEY="your-deepseek-key"
COHERE_API_KEY="your-cohere-key"

# ── Ollama (Local Backup) ───────────────────────────────────────────────────
OLLAMA_BASE_URL="http://ollama:11434"

# ── Paperclip Runtime ────────────────────────────────────────────────────────
PAPERCLIP_PORT=4100
PAPERCLIP_DATABASE_URL="postgresql://postgres:postgres@postgres:5432/crm_db"

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://redis:6379"

# ── Internal Services ────────────────────────────────────────────────────────
SCRAPER_API_URL="http://google-maps-scraper:8080"
BROWSERLESS_URL="ws://browserless:3000"
BROWSERLESS_TOKEN="wootech-token"
FIRECRAWL_URL="http://firecrawl:3002"
FIRECRAWL_API_KEY="local"
UNSTRUCTURED_URL="http://unstructured:8000"
CNPJ_SERVICE_URL="http://cnpj-service:4000"
COLLY_SERVICE_URL="http://colly-service:5000"
WHATSAPP_API_URL="http://whatsapp-service:8080"
